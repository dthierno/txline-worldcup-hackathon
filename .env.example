TXLINE_NETWORK=devnet
TXLINE_API_ORIGIN=https://txline-dev.txodds.com
TXLINE_JWT=
TXLINE_API_TOKEN=

# Optional: automatically enrich TxLINE lineups with player headshots.
API_FOOTBALL_KEY=
API_FOOTBALL_ORIGIN=https://v3.football.api-sports.io

# Telegram bot: the bot's @username (without @), used to build the connect
# deep link (t.me/<username>?start=<token>). The bot TOKEN and webhook secret
# live on the Convex deployment, not here:
#   npx convex env set TELEGRAM_BOT_TOKEN <token-from-BotFather>
#   npx convex env set TELEGRAM_WEBHOOK_SECRET <random-secret>
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=
